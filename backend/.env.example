# Environment variables for Docker Compose
# Copy this file to .env and update with your actual values

# Database Configuration
POSTGRES_PASSWORD=YourSecurePassword123!
DATABASE_URL=postgresql://postgres:YourSecurePassword123!@postgres:5432/panameconsultingDb?schema=public

# Redis Configuration - Support Dual-Stack IPv4/IPv6
# Format: redis://[password@]host[:port][/database]
# IPv4: redis://:YourRedisPassword123!@127.0.0.1:6379/0
# IPv6: redis://:YourRedisPassword123!@[::1]:6379/0
REDIS_URL=redis://:YourRedisPassword123!@localhost:6379/0
REDIS_ENABLED=true

# JWT Configuration (Generate new secrets for production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Paname Consulting

# Application Configuration
APP_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Security Configuration
COOKIE_SECRET=your-super-secret-cookie-key-min-32-chars

# Bull Board Configuration
ADMIN_EMAIL=admin@panameconsulting.com
BULL_BOARD_PORT=8082

# Production Settings
NODE_ENV=production
LOG_LEVEL=info

# Server Configuration
PORT=10000
HOST=0.0.0.0
DOMAIN=your-domain.com

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
