{
  "name": "paname-consulting",
  "version": "1.0.0",
  "description": "Application Paname Consulting avec backend NestJS et frontend React",
  
  "providers": {
    "node": {
      "version": "20.11.0",
      "packageManager": "pnpm",
      "packageManagerVersion": "8.15.0"
    },
    "postgresql": {
      "version": "16",
      "extensions": ["pgcrypto", "uuid-ossp"]
    }
  },

  "build": {
    "cmd": "npm install -g pnpm && cd backend && pnpm install --frozen-lockfile && pnpm prisma generate && pnpm run build",
    
    "cache": {
      "directories": [
        "backend/node_modules",
        "backend/.pnpm-store",
        "backend/node_modules/.prisma"
      ],
      "ttl": "7d"
    },

    "output": {
      "include": [
        "backend/dist",
        "backend/node_modules",
        "backend/prisma",
        "backend/package.json",
        "package.json",
        "pnpm-lock.yaml"
      ],
      "exclude": [
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/node_modules/.cache",
        "**/.git"
      ]
    }
  },

  "start": {
    "cmd": "npm install -g pnpm && cd backend && pnpm prisma migrate deploy && node dist/src/main.js",
    "env": {
      "NODE_ENV": "production",
      "PORT": "{{env.PORT}}",
      "DATABASE_URL": "{{env.DATABASE_URL}}",
      "EMAIL_PORT": "587",
      "EMAIL_SERVICE": "gmail",
      "EMAIL_USER": "{{env.EMAIL_USER}}",
      "CLOUDINARY_URL": "{{env.CLOUDINARY_URL}}",
      "EMAIL_PASS": "{{env.EMAIL_PASS}}",
      "COOKIE_SECRET": "{{env.COOKIE_SECRET}}",
      "JWT_SECRET": "{{env.JWT_SECRET}}",
      "CORS_ORIGIN": "{{env.CORS_ORIGIN}}"
    }
  },

  "deploy": {
    "target": "railway",
    "features": {
      "metrics": true,
      "logs": true,
      "backups": true
    },
    "scaling": {
      "min": 1,
      "max": 3,
      "cpu": 0.5,
      "memory": 512
    }
  },

  "apt": {
    "packages": [
      "openssl",
      "ca-certificates",
      "curl",
      "git"
    ]
  },

  "env": {
    "NODE_ENV": {
      "default": "development",
      "description": "Environnement d'exécution"
    },
    "PORT": {
      "default": "10000",
      "description": "Port d'écoute du serveur"
    },
    "DATABASE_URL": {
      "required": true,
      "description": "URL de connexion PostgreSQL"
    },
    "COOKIE_SECRET": {
      "required": true,
      "description": "Secret pour signer les cookies",
      "sensitive": true
    },
    "JWT_SECRET": {
      "required": true,
      "description": "Secret pour les tokens JWT",
      "sensitive": true
    },
    "CORS_ORIGIN": {
      "default": "https://panameconsulting.vercel.app",
      "description": "Origines autorisées pour CORS"
    }
  },

  "secrets": {
    "COOKIE_SECRET": {
      "description": "Secret pour les cookies",
      "generate": true
    },
    "SESSION_SECRET": {
      "description": "Secret pour les sessions",
      "generate": true
    },
    "JWT_SECRET": {
      "description": "Secret pour JWT",
      "generate": true
    }
  },

  "hooks": {
    "prebuild": [
      "echo '🚀 Début du build Paname Consulting'",
      "npm install -g pnpm",
      "pnpm --version",
      "node --version"
    ],
    "postbuild": [
      "echo '✅ Build terminé avec succès'",
      "ls -la backend/dist"
    ],
    "prestart": [
      "echo '🔧 Vérification des migrations Prisma...'",
      "cd backend && pnpm prisma migrate status"
    ],
    "poststart": [
      "echo '✨ Application démarrée sur le port {{env.PORT}}'"
    ]
  },

  "monitoring": {
    "metrics": {
      "enabled": true,
      "path": "/metrics",
      "port": "{{env.PORT}}"
    },
    "logging": {
      "level": "info",
      "format": "json",
      "output": "stdout"
    }
  },

  "resources": {
    "limits": {
      "cpu": "1",
      "memory": "1024Mi"
    },
    "requests": {
      "cpu": "0.25",
      "memory": "256Mi"
    }
  }
}