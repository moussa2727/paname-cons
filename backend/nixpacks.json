{
  "version": 1,
  "buildCommand": "pnpm install && pnpm build",
  "startCommand": "pnpm start",
  "env": {
    "NODE_ENV": "production"
  },
  "phases": {
    "build": {
      "deps": [
        {
          "type": "npm",
          "name": "pnpm",
          "version": "latest"
        }
      ],
      "cmds": [
        "corepack enable && corepack prepare pnpm@latest --activate",
        "pnpm install --frozen-lockfile",
        "pnpm prisma generate",
        "pnpm build"
      ]
    },
    "run": {
      "cmds": [
        "pnpm prisma migrate deploy || true",
        "pnpm start"
      ]
    }
  }
}
