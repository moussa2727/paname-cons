// ==================== MIGRATIONS & EXTENSIONS ====================

// Extension pour la recherche full-text
// run `CREATE EXTENSION IF NOT EXISTS pg_trgm;` on your database

// Index pour la recherche full-text sur plusieurs tables
// Ces indexes seront créés manuellement ou via des migrations SQL
// ```
// CREATE INDEX CONCURRENTLY IF NOT EXISTS users_email_trgm_idx ON users USING GIN (email gin_trgm_ops);
// CREATE INDEX CONCURRENTLY IF NOT EXISTS procedures_search_idx ON procedures USING GIN (to_tsvector('french', prenom || ' ' || nom || ' ' || email));
// ```
