  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "dev": "nest start --watch --debug",
    "start": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "generate": "prisma generate",
    "migrate": "prisma migrate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:prod": "prisma migrate deploy && prisma generate",
    "studio": "prisma studio",
    "Preset": "prisma migrate reset --force",
    "postinstall": "prisma generate",
    "railway:deploy": "chmod +x scripts/railway-deploy.sh && ./scripts/railway-deploy.sh"
