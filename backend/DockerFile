# ============ BUILD ============
FROM node:20-alpine AS builder

WORKDIR /app

# Installer openssl pour Prisma avec PostgreSQL
RUN apk add --no-cache openssl

# Copier les fichiers de dépendances
COPY package.json pnpm-lock.yaml* ./

RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --frozen-lockfile

# Copier tout le code source
COPY . .

# DEBUG: Vérifier ce qui a été copié
RUN ls -la && echo "---" && ls -la prisma/ || echo "prisma folder not found"

# Générer le client Prisma
RUN pnpm prisma generate

# Build de l'application
RUN pnpm build


# ============ PRODUCTION ============
FROM node:20-alpine AS production

ENV NODE_ENV=production
ENV PORT=10000
ENV EMAIL_USER=${EMAIL_USER}
ENV EMAIL_PASS=${EMAIL_PASS}
ENV REDIS_URL=${REDIS_URL}
ENV JWT_SECRET=${JWT_SECRET}
ENV JWT_EXPIRES_IN=${JWT_EXPIRES_IN}
ENV COOKIE_SECRET=${COOKIE_SECRET}
ENV CLOUDINARY_URL=${CLOUDINARY_URL}

# Ne pas utiliser ARG/ENV pour les secrets pour éviter les warnings
# Les secrets seront injectés via --env-file ou docker-compose

RUN apk add --no-cache openssl

WORKDIR /app

COPY --from=builder /app/package.json ./
COPY --from=builder /app/pnpm-lock.yaml* ./

RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --prod --frozen-lockfile

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma 

RUN mkdir -p logs backups && \
    chown -R node:node /app

USER node

EXPOSE 10000

CMD ["node", "dist/src/main.js"]