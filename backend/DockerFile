# ============ BUILD ============
FROM node:20-alpine AS builder

WORKDIR /app

# Installer openssl pour Prisma avec PostgreSQL
RUN apk add --no-cache openssl

COPY package.json pnpm-lock.yaml* ./

RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --frozen-lockfile

COPY . .

# Générer le client Prisma
RUN pnpm prisma generate

# Build de l'application
RUN pnpm build


# ============ PRODUCTION ============
FROM node:20-alpine AS production

ARG NODE_ENV=production
ENV NODE_ENV=${NODE_ENV}
ENV PORT=10000

# Utiliser ARG pour les variables d'environnement (mais pas ENV pour les secrets)
ARG EMAIL_USER
ARG EMAIL_PASS
ARG REDIS_URL
ARG JWT_SECRET
ARG JWT_EXPIRES_IN
ARG COOKIE_SECRET
ARG CLOUDINARY_URL
ARG DATABASE_URL

# Passer les ARG en ENV
ENV EMAIL_USER=${EMAIL_USER}
ENV EMAIL_PASS=${EMAIL_PASS}
ENV REDIS_URL=${REDIS_URL}
ENV JWT_SECRET=${JWT_SECRET}
ENV JWT_EXPIRES_IN=${JWT_EXPIRES_IN}
ENV COOKIE_SECRET=${COOKIE_SECRET}
ENV CLOUDINARY_URL=${CLOUDINARY_URL}
ENV DATABASE_URL=${DATABASE_URL}

# Installer openssl pour PostgreSQL et Prisma
RUN apk add --no-cache openssl

WORKDIR /app

# Copier package.json depuis builder
COPY --from=builder /app/package.json ./
COPY --from=builder /app/pnpm-lock.yaml* ./

RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --prod --frozen-lockfile

# Copier le build
COPY --from=builder /app/dist ./dist

# Copier les fichiers Prisma (déjà générés)
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma

# Créer dossiers corrects
RUN mkdir -p logs backups && \
    chown -R node:node /app

USER node

EXPOSE 10000

# Commande simple - Prisma est déjà généré dans le build
CMD ["node", "dist/src/main.js"]