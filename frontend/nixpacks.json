{
  "version": 1,
  "buildCommand": "pnpm install && pnpm build",
  "startCommand": "nginx -g 'daemon off;'",
  "env": {
    "NODE_ENV": "production"
  },
  "phases": {
    "build": {
      "deps": [
        {
          "type": "npm",
          "name": "pnpm",
          "version": "latest"
        }
      ],
      "cmds": [
        "corepack enable && corepack prepare pnpm@latest --activate",
        "pnpm install --frozen-lockfile",
        "pnpm build"
      ]
    },
    "run": {
      "cmds": [
        "cp -r dist/* /usr/share/nginx/html/",
        "nginx -g 'daemon off;'"
      ]
    }
  }
}
